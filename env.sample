# Copier en .env (non versionné) et renseigner les valeurs.
# Utilisé par docker-compose ET par Prisma CLI en local.

# --- Base de données MySQL (conteneur "db" du docker-compose) ---
MYSQL_ROOT_PASSWORD=change-moi-root
MYSQL_DATABASE=blueportel
MYSQL_USER=blueportel
MYSQL_PASSWORD=change-moi

# URL de connexion Prisma.
# - En Docker : l'hôte est "db" (nom du service). Le compose la construit déjà,
#   cette valeur sert surtout à Prisma CLI en local (db push / studio).
# - En local sans Docker : pointer vers ton MySQL (ex. localhost:3306).
DATABASE_URL=mysql://blueportel:change-moi@localhost:3306/blueportel

# --- Paiement Mollie ---
# Clé test_... pour développer, live_... en production. https://my.mollie.com → Développeurs → Clés API
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- URL publique du site (HTTPS en prod) ---
# Sert aux redirectUrl / webhookUrl Mollie. En local le webhook est ignoré automatiquement.
NEXT_PUBLIC_SITE_URL=https://blueportel.fr
